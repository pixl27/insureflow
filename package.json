{
  "name": "insureflow-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "INSUREFLOW SaaS Insurance Platform",
  "workspaces": [
    "apps/*",
    "api/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start:all": "node start-all.js"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
